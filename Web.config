<?xml version="1.0" encoding="utf-8"?>
<!--
    Author:      Ian Lim
    Description: Application Configuration and Connection Strings
    Date:        23/5/2026
-->
<configuration>
  <appSettings>
    <!-- Disable unobtrusive validation (requires jQuery otherwise) -->
    <add key="ValidationSettings:UnobtrusiveValidationMode" value="None" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
    <sessionState timeout="30" />
  </system.web>

  <connectionStrings>
    <!-- LocalDB connection — InsightLearn.mdf must exist in App_Data folder -->
    <add name="InsightLearnDB"
         connectionString="Data Source=(LocalDB)\MSSQLLocalDB;AttachDbFilename=|DataDirectory|\InsightLearn.mdf;Initial Catalog=InsightLearn;Integrated Security=True"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <system.webServer>
    <modules runAllManagedModulesForAllRequests="true" />
  </system.webServer>
</configuration>
